# ============================================
# MSP Monitoring - Environment Variables
# ============================================

# VictoriaMetrics
VM_RETENTION=90d
VM_WRITE_PORT=8428
VM_AUTH_USER=vmwrite
VM_AUTH_PASSWORD=changeme

# Grafana
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=changeme

# Nginx
NGINX_BASIC_AUTH_USER=admin
NGINX_BASIC_AUTH_PASSWORD=changeme
NGINX_HTTP_PORT=8880
NGINX_HTTPS_PORT=8443

# Alerting - SMTP (Phase 3)
# make alertmanager-config 실행 후 config/alertmanager/alertmanager.yml 생성
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_FROM=msp-alerts@yourcompany.com
SMTP_USERNAME=msp-alerts@yourcompany.com
SMTP_PASSWORD=your-app-password
ALERT_EMAIL_TO=ops@yourcompany.com
