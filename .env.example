# ============================================
# MSP Monitoring - Environment Variables
# ============================================

# VictoriaMetrics
VM_RETENTION=90d
VM_WRITE_PORT=8428
VM_AUTH_USER=vmwrite
VM_AUTH_PASSWORD=changeme

# Grafana
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=changeme

# Nginx
NGINX_BASIC_AUTH_USER=admin
NGINX_BASIC_AUTH_PASSWORD=changeme
NGINX_HTTP_PORT=8880
NGINX_HTTPS_PORT=8443

# MSP Portal
PORTAL_JWT_SECRET=change-this-to-a-random-secret
PORTAL_INIT_USER=admin
PORTAL_INIT_PASSWORD=changeme123

# Alerting - SMTP
# 포털에서 알람 이메일 설정 시 사용. 포털 DB에 이메일/임계값 저장 후 자동 생성.
SMTP_HOST=smtp.worksmobile.com
SMTP_PORT=587
SMTP_FROM=your-address@yourcompany.com
SMTP_USERNAME=your-address@yourcompany.com
SMTP_PASSWORD=your-smtp-password
