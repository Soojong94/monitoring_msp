// ============================================
// MSP Monitoring - Direct Agent Config (Windows)
// ============================================
// Collects Windows metrics and remaps to node_exporter-compatible
// names so Linux/Windows share the same Grafana dashboard.
//
// Required env vars:
//   CUSTOMER_ID, SERVER_NAME, CSP, REGION, ENVIRONMENT, REMOTE_WRITE_URL

// --- Windows OS metric collection ---
prometheus.exporter.windows "node" {
  enabled_collectors = [
    "cpu",
    "cs",           // physical memory total
    "memory",
    "logical_disk",
    "net",
    "os",
    "system",
    "time",
  ]
}

// --- Scrape every 15s ---
prometheus.scrape "node" {
  targets         = prometheus.exporter.windows.node.targets
  forward_to      = [prometheus.relabel.win_compat.receiver]
  scrape_interval = "15s"
  scrape_timeout  = "10s"
}

// --- Remap Windows metrics → node_exporter-compatible names ---
prometheus.relabel "win_compat" {
  forward_to = [prometheus.relabel.add_labels.receiver]

  // CPU: windows_cpu_time_total -> node_cpu_seconds_total
  // mode labels (idle, user, system, ...) are identical
  rule {
    source_labels = ["__name__"]
    regex         = "windows_cpu_time_total"
    target_label  = "__name__"
    replacement   = "node_cpu_seconds_total"
  }

  // Memory available
  rule {
    source_labels = ["__name__"]
    regex         = "windows_memory_available_bytes"
    target_label  = "__name__"
    replacement   = "node_memory_MemAvailable_bytes"
  }

  // Memory total (cs collector: windows_cs_physical_memory_bytes)
  rule {
    source_labels = ["__name__"]
    regex         = "windows_cs_physical_memory_bytes"
    target_label  = "__name__"
    replacement   = "node_memory_MemTotal_bytes"
  }

  // Disk free bytes
  rule {
    source_labels = ["__name__"]
    regex         = "windows_logical_disk_free_bytes"
    target_label  = "__name__"
    replacement   = "node_filesystem_avail_bytes"
  }

  // Disk size bytes
  rule {
    source_labels = ["__name__"]
    regex         = "windows_logical_disk_size_bytes"
    target_label  = "__name__"
    replacement   = "node_filesystem_size_bytes"
  }

  // Rename 'volume' label (C:, D:) → 'mountpoint' for filesystem metrics
  rule {
    source_labels = ["volume"]
    regex         = "(.+)"
    target_label  = "mountpoint"
    replacement   = "$1"
  }

  // Also copy 'volume' → 'device' for disk I/O metrics (node_disk_* uses device label)
  rule {
    source_labels = ["volume"]
    regex         = "(.+)"
    target_label  = "device"
    replacement   = "$1"
  }

  // Add fstype=NTFS so dashboard fstype filters pass through
  rule {
    source_labels = ["__name__"]
    regex         = "node_filesystem_(avail|size)_bytes"
    target_label  = "fstype"
    replacement   = "NTFS"
  }

  // OS info: windows_os_info → node_uname_info
  rule {
    source_labels = ["__name__"]
    regex         = "windows_os_info"
    target_label  = "__name__"
    replacement   = "node_uname_info"
  }

  // Uptime: windows_system_system_up_time → node_time_seconds
  // (dashboard shows uptime via this metric)
  rule {
    source_labels = ["__name__"]
    regex         = "windows_system_system_up_time"
    target_label  = "__name__"
    replacement   = "windows_uptime_seconds"
  }

  // Disk I/O read: windows_logical_disk_read_bytes_total → node_disk_read_bytes_total
  rule {
    source_labels = ["__name__"]
    regex         = "windows_logical_disk_read_bytes_total"
    target_label  = "__name__"
    replacement   = "node_disk_read_bytes_total"
  }

  // Disk I/O write: windows_logical_disk_write_bytes_total → node_disk_written_bytes_total
  rule {
    source_labels = ["__name__"]
    regex         = "windows_logical_disk_write_bytes_total"
    target_label  = "__name__"
    replacement   = "node_disk_written_bytes_total"
  }

  // Network receive bytes: windows_net_bytes_received_total → node_network_receive_bytes_total
  rule {
    source_labels = ["__name__"]
    regex         = "windows_net_bytes_received_total"
    target_label  = "__name__"
    replacement   = "node_network_receive_bytes_total"
  }

  // Network transmit bytes: windows_net_bytes_sent_total → node_network_transmit_bytes_total
  rule {
    source_labels = ["__name__"]
    regex         = "windows_net_bytes_sent_total"
    target_label  = "__name__"
    replacement   = "node_network_transmit_bytes_total"
  }

  // Rename 'nic' label → 'device' for network metrics
  rule {
    source_labels = ["nic"]
    regex         = "(.+)"
    target_label  = "device"
    replacement   = "$1"
  }
}

// --- Add customer/server labels ---
prometheus.relabel "add_labels" {
  forward_to = [prometheus.remote_write.central.receiver]

  rule {
    action       = "replace"
    target_label = "customer_id"
    replacement  = env("CUSTOMER_ID")
  }

  rule {
    action       = "replace"
    target_label = "server_name"
    replacement  = env("SERVER_NAME")
  }

  rule {
    action       = "replace"
    target_label = "csp"
    replacement  = env("CSP")
  }

  rule {
    action       = "replace"
    target_label = "region"
    replacement  = env("REGION")
  }

  rule {
    action       = "replace"
    target_label = "environment"
    replacement  = env("ENVIRONMENT")
  }

  rule {
    action       = "replace"
    target_label = "os"
    replacement  = "windows"
  }
}

// --- Remote write to central server ---
prometheus.remote_write "central" {
  endpoint {
    url = env("REMOTE_WRITE_URL")

    queue_config {
      capacity             = 2500
      max_shards           = 4
      min_shards           = 1
      max_samples_per_send = 500
      batch_send_deadline  = "5s"
      min_backoff          = "30ms"
      max_backoff          = "5s"
    }
  }
}
